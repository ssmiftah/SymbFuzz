// Auto-generated Verilator simulation harness for module: {{ module }}
// Protocol: line-delimited JSON over stdin/stdout (same shape as the xsim
// TCL bridge — see symfuzz/drivers/base.py for the command set).

#include "V{{ module }}.h"
#include "V{{ module }}___024root.h"
#include <verilated.h>
{% if native_coverage %}
#include <verilated_cov.h>
{% endif %}

#include <cstdint>
#include <cstdio>
#include <fstream>
#include <iostream>
#include <regex>
#include <sstream>
#include <string>
#include <utility>
#include <vector>

static V{{ module }}*      top = nullptr;
static VerilatedContext*   ctx = nullptr;

// ---- Clocking --------------------------------------------------------- //

static void clk_posedge() {
    // Single-run rising-edge toggle — matches the xsim TCL bridge.
    top->{{ clock_port }} = 0;
    top->eval();
    top->{{ clock_port }} = 1;
    top->eval();
}

// ---- Input routing ---------------------------------------------------- //

static void set_input(const std::string& name, uint64_t val) {
{% for inp in data_inputs %}
    if (name == "{{ inp.name }}") { top->{{ inp.name }} = (decltype(top->{{ inp.name }}))val; return; }
{% endfor %}
}

static void force_reg(const std::string& name, uint64_t val) {
{% for reg in registers %}
    if (name == "{{ reg.arch_name }}") { top->rootp->{{ module }}__DOT__{{ reg.verilator_path }} = (decltype(top->rootp->{{ module }}__DOT__{{ reg.verilator_path }}))val; return; }
{% endfor %}
}

// ---- State emission --------------------------------------------------- //

static std::string emit_state_str() {
    std::ostringstream os;
    os << "{";
{% for reg in registers %}
    os << "\"{{ reg.arch_name }}\":" << (uint64_t)(top->rootp->{{ module }}__DOT__{{ reg.verilator_path }}){% if not loop.last %} << ","{% endif %};
{% endfor %}
    os << "}";
    return os.str();
}

// ---- JSON helpers (narrow, for our known message shapes only) --------- //

static int64_t json_get_int(const std::string& s, const std::string& key, int64_t def = -1) {
    std::regex re("\"" + key + "\"\\s*:\\s*(-?\\d+)");
    std::smatch m;
    if (std::regex_search(s, m, re)) return std::stoll(m[1].str());
    return def;
}

// Body of "key":{...} (contents inside the braces, depth-balanced). "" if absent.
static std::string json_get_object(const std::string& s, const std::string& key) {
    std::string pat = "\"" + key + "\"";
    size_t p = s.find(pat);
    if (p == std::string::npos) return "";
    size_t b = s.find('{', p + pat.size());
    if (b == std::string::npos) return "";
    int depth = 1;
    size_t i = b + 1;
    while (i < s.size() && depth > 0) {
        if (s[i] == '{') depth++;
        else if (s[i] == '}') depth--;
        i++;
    }
    if (depth != 0) return "";
    return s.substr(b + 1, i - b - 2);
}

// Body of "key":[...]  (without the outer brackets). "" if absent.
static std::string json_get_array(const std::string& s, const std::string& key) {
    std::string pat = "\"" + key + "\"";
    size_t p = s.find(pat);
    if (p == std::string::npos) return "";
    size_t b = s.find('[', p + pat.size());
    if (b == std::string::npos) return "";
    int depth = 1;
    size_t i = b + 1;
    while (i < s.size() && depth > 0) {
        if (s[i] == '[') depth++;
        else if (s[i] == ']') depth--;
        i++;
    }
    if (depth != 0) return "";
    return s.substr(b + 1, i - b - 2);
}

// Iterate top-level {...} substrings inside a JSON array body.
static std::vector<std::string> json_split_objs(const std::string& body) {
    std::vector<std::string> out;
    size_t i = 0, n = body.size();
    while (i < n) {
        if (body[i] == '{') {
            int depth = 1;
            size_t start = i;
            i++;
            while (i < n && depth > 0) {
                if (body[i] == '{') depth++;
                else if (body[i] == '}') depth--;
                i++;
            }
            out.push_back(body.substr(start, i - start));
        } else {
            i++;
        }
    }
    return out;
}

// Extract "key":integer pairs from a JSON object body (used for inputs/state).
static std::vector<std::pair<std::string, uint64_t>> json_parse_kv(const std::string& body) {
    std::vector<std::pair<std::string, uint64_t>> out;
    std::regex re("\"(\\w+)\"\\s*:\\s*(\\d+)");
    auto begin = std::sregex_iterator(body.begin(), body.end(), re);
    auto end   = std::sregex_iterator();
    for (auto it = begin; it != end; ++it) {
        out.emplace_back((*it)[1].str(), std::stoull((*it)[2].str()));
    }
    return out;
}

// Escape backslashes and double quotes for safe JSON string emission.
static std::string json_escape(const std::string& s) {
    std::string out;
    out.reserve(s.size() + 8);
    for (char c : s) {
        switch (c) {
            case '\\': out += "\\\\"; break;
            case '"':  out += "\\\""; break;
            case '\n': out += "\\n";  break;
            case '\r': out += "\\r";  break;
            case '\t': out += "\\t";  break;
            default:
                if (static_cast<unsigned char>(c) < 0x20) {
                    char buf[8];
                    std::snprintf(buf, sizeof(buf), "\\u%04x", c);
                    out += buf;
                } else {
                    out.push_back(c);
                }
        }
    }
    return out;
}

// ---- Main REPL -------------------------------------------------------- //

int main(int argc, char** argv) {
    ctx = new VerilatedContext;
    ctx->commandArgs(argc, argv);
    top = new V{{ module }}(ctx);

    // Initial idle state — clock low, reset asserted. Matches the xsim
    // bridge initialisation preamble.
    top->{{ clock_port }} = 0;
{% if reset_port %}
    top->{{ reset_port }} = {{ "0" if reset_active_low else "1" }};
{% endif %}
    top->eval();

    std::string line;
    while (std::getline(std::cin, line)) {
        // Order matters: longest command names first so shorter prefixes
        // don't shadow them (step_raw_trace before step_raw before step_trace
        // before step).
        if (line.find("\"cmd\":\"step_raw_trace\"") != std::string::npos) {
            // Raw batch: each dict's inputs drive every port (clock
            // included with the caller-specified polarity), then one
            // eval() per dict. No cycle-wrap — used by BMC replay to
            // honour clk2fflogic's half-cycle semantics.
            std::string body = json_get_array(line, "inputs");
            std::vector<std::string> objs = json_split_objs(body);
            std::ostringstream states;
            states << "[";
            bool first = true;
            std::string err;
            for (const auto& obj : objs) {
                try {
                    for (const auto& kv : json_parse_kv(obj)) {
                        if (kv.first == "{{ clock_port }}") {
                            top->{{ clock_port }} = (decltype(top->{{ clock_port }}))kv.second;
                        } else {
                            set_input(kv.first, kv.second);
                        }
                    }
                    top->eval();
                    if (!first) states << ",";
                    states << emit_state_str();
                    first = false;
                } catch (const std::exception& e) {
                    err = e.what();
                    break;
                }
            }
            states << "]";
            if (err.empty()) {
                std::cout << "{\"states\":" << states.str() << "}\n";
            } else {
                std::cout << "{\"states\":" << states.str()
                          << ",\"error\":\"" << json_escape(err) << "\"}\n";
            }
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"step_raw\"") != std::string::npos) {
            std::string inputs = json_get_object(line, "inputs");
            for (const auto& kv : json_parse_kv(inputs)) {
                if (kv.first == "{{ clock_port }}") {
                    top->{{ clock_port }} = (decltype(top->{{ clock_port }}))kv.second;
                } else {
                    set_input(kv.first, kv.second);
                }
            }
            top->eval();
            std::cout << "{\"state\":" << emit_state_str() << "}\n";
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"step_trace\"") != std::string::npos) {
            std::string body = json_get_array(line, "inputs");
            std::vector<std::string> objs = json_split_objs(body);
            std::ostringstream states;
            states << "[";
            bool first = true;
            std::string err;
            for (const auto& obj : objs) {
                try {
                    for (const auto& kv : json_parse_kv(obj)) {
                        set_input(kv.first, kv.second);
                    }
                    clk_posedge();
                    if (!first) states << ",";
                    states << emit_state_str();
                    first = false;
                } catch (const std::exception& e) {
                    err = e.what();
                    break;
                }
            }
            states << "]";
            if (err.empty()) {
                std::cout << "{\"states\":" << states.str() << "}\n";
            } else {
                std::cout << "{\"states\":" << states.str()
                          << ",\"error\":\"" << json_escape(err) << "\"}\n";
            }
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"step\"") != std::string::npos) {
            std::string inputs = json_get_object(line, "inputs");
            for (const auto& kv : json_parse_kv(inputs)) set_input(kv.first, kv.second);
            clk_posedge();
            std::cout << "{\"state\":" << emit_state_str() << "}\n";
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"reset\"") != std::string::npos) {
            int64_t cycles = json_get_int(line, "cycles", 5);
            if (cycles < 0) cycles = 5;
            // Zero all data inputs so lingering values do not bleed through
            // the trailing post-deassertion edge (same fix as tcl_bridge).
{% for inp in data_inputs %}
            top->{{ inp.name }} = 0;
{% endfor %}
{% if reset_port %}
            top->{{ reset_port }} = {{ "0" if reset_active_low else "1" }};
{% endif %}
            for (int64_t i = 0; i < cycles; i++) clk_posedge();
{% if reset_port %}
            top->{{ reset_port }} = {{ "1" if reset_active_low else "0" }};
{% endif %}
            clk_posedge();
            std::cout << "{\"ok\":true}\n";
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"read_state\"") != std::string::npos) {
            std::cout << "{\"state\":" << emit_state_str() << "}\n";
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"force\"") != std::string::npos) {
            std::string body = json_get_object(line, "state");
            for (const auto& kv : json_parse_kv(body)) force_reg(kv.first, kv.second);
            std::cout << "{\"ok\":true}\n";
            std::cout.flush();
        }
{% if native_coverage %}
        else if (line.find("\"cmd\":\"coverage\"") != std::string::npos) {
            // Dump current coverage to a .dat file under the working dir,
            // then stream it back as a JSON-escaped string. VerilatedCov
            // accumulates; no reset on read, so successive calls return
            // monotonically growing hit-sets.
            const char* path = "verilator_cov.dat";
            VerilatedCov::write(path);
            std::ifstream f(path);
            std::string body;
            if (f.good()) {
                std::ostringstream ss;
                ss << f.rdbuf();
                body = ss.str();
            }
            std::cout << "{\"report\":\"" << json_escape(body) << "\"}\n";
            std::cout.flush();
        }
{% endif %}
        else if (line.find("\"cmd\":\"checkpoint\"") != std::string::npos) {
            std::cout << "{\"error\":\"checkpoint: unsupported on verilator\"}\n";
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"restore\"") != std::string::npos) {
            std::cout << "{\"error\":\"restore: unsupported on verilator\"}\n";
            std::cout.flush();
        }
        else if (line.find("\"cmd\":\"quit\"") != std::string::npos) {
            break;
        }
    }

    top->final();
    delete top;
    delete ctx;
    return 0;
}
